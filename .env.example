# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=novadrive
POSTGRES_USER=novadrive
POSTGRES_PASSWORD=supersecret

# MongoDB
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=novadrive_telemetry
MONGO_USER=novadrive
MONGO_PASSWORD=supersecret

# JWT
JWT_SECRET=change_me_to_a_32_char_minimum_secret_key
JWT_ISSUER=novadrive
JWT_AUDIENCE=novadrive-clients
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Email (Mailpit defaults for local dev)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@novadrive.local
SMTP_FROM_NAME=Nova Drive

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Vehicle API Key (generated by seed)
VEHICLE_API_KEY=change_me_after_first_run

# Seq logging
SEQ_URL=http://seq

# ASP.NET runtime
ASPNETCORE_ENVIRONMENT=Production